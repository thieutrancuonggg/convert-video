{
  "name": "video-affiliate-tool",
  "version": "1.0.0",
  "description": "TikTok Affiliate Video Variation Tool - tạo 3 biến thể video từ video gốc",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon --ignore uploads/ --ignore outputs/ src/server.js",
    "clean": "node -e \"const fs=require('fs-extra');fs.emptyDirSync('uploads');fs.emptyDirSync('outputs');console.log('Cleaned uploads & outputs');\""
  },
  "dependencies": {
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "archiver": "^7.0.1",
    "compression": "^1.7.4",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-ejs-layouts": "^2.5.1",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "fs-extra": "^11.2.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
