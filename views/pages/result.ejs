<div class="page-result">
  <div class="result-header">
    <h1>✅ Tạo xong 3 biến thể!</h1>
    <p class="text-muted">File gốc: <code><%= job.originalFilename %></code></p>
    <div class="product-name-badge">
      <span class="product-name-label">Tên sản phẩm</span>
      <span class="product-name-value"><%= job.productName %></span>
    </div>
  </div>

  <% if (job.warning) { %>
  <div class="alert alert-warning">
    ⚠️ <%= job.warning %>
  </div>
  <% } %>

  <!-- Video grid -->
  <div class="video-grid">
    <% job.outputs.forEach(function(output, i) { %>
    <div class="video-card">
      <div class="video-wrap">
        <video
          src="/preview/<%= jobId %>/<%= output.filename %>"
          controls
          preload="metadata"
          playsinline
        ></video>
      </div>
      <div class="video-info">
        <div class="video-badge badge-v<%= i+1 %>"><%= output.label %></div>
        <p class="video-desc"><%= output.description %></p>
        <a
          href="/download/<%= jobId %>/<%= output.filename %>"
          class="btn btn-secondary btn-sm"
          download
        >
          ⬇ Tải xuống
        </a>
      </div>
    </div>
    <% }) %>
  </div>

  <!-- Action bar -->
  <div class="result-actions">
    <a href="/download/<%= jobId %>/zip" class="btn btn-primary">
      📦 Tải tất cả (ZIP)
    </a>
    <a href="/" class="btn btn-secondary">
      ↩ Tạo video khác
    </a>
  </div>

  <p class="result-note text-muted">
    File lưu trên máy — link download hoạt động cho đến khi bạn restart server
    hoặc sau <%= 24 %> giờ hệ thống tự dọn dẹp.
  </p>
</div>
