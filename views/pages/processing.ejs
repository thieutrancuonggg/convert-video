<div class="page-processing" data-job-id="<%= jobId %>">
  <div class="processing-box">
    <div class="spinner"></div>
    <h1 class="processing-title">Đang tạo 3 biến thể video…</h1>
    <p id="status-text" class="processing-subtitle">
      Hệ thống đang render từng phiên bản tuần tự.
      Vui lòng <strong>không tắt trang</strong> này.
    </p>

    <div class="progress-wrap">
      <div class="progress-bar">
        <div id="progress-fill" class="progress-fill" style="width:<%= job.progress %>%"></div>
      </div>
      <span id="progress-pct" class="progress-pct"><%= job.progress %>%</span>
    </div>

    <p class="processing-note">
      Video 30s thường mất 1–3 phút tùy cấu hình máy.
    </p>
  </div>
</div>

<script>
  // Polling script — injected directly on this page
  (function() {
    const jobId = document.querySelector('[data-job-id]').dataset.jobId;
    const fill   = document.getElementById('progress-fill');
    const pct    = document.getElementById('progress-pct');
    const status = document.getElementById('status-text');

    async function poll() {
      try {
        const r    = await fetch('/jobs/' + jobId + '/status');
        const body = await r.json();
        const job  = body.data;

        if (fill) fill.style.width = (job.progress || 0) + '%';
        if (pct)  pct.textContent  = (job.progress || 0) + '%';

        if (job.status === 'completed') {
          if (fill) fill.style.width = '100%';
          if (pct)  pct.textContent  = '100%';
          if (status) status.textContent = '✅ Hoàn thành! Đang chuyển hướng…';
          setTimeout(() => { window.location.href = '/result/' + jobId; }, 600);
          return;
        }

        if (job.status === 'failed') {
          if (status) status.innerHTML = '❌ Lỗi: ' + (job.errorMessage || 'Không xác định');
          return;
        }

        setTimeout(poll, 2000);
      } catch (_) {
        setTimeout(poll, 3000);
      }
    }

    poll();
  })();
</script>
